# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./budgetforge.db

# ── LLM Provider API keys ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
DEEPSEEK_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434

# ── SMTP alerts (optional — can also be set via /api/settings UI) ───────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
